# ══════════════════════════════════════════════════════════════
# PAS-SCADA-Kafka-Bridge — Environment Variables Template
#
# Copy this file to .env and fill in your values.
# Never commit .env to git.
#
# Usage:
#   cp .env.example .env
#   docker compose --env-file .env up -d
# ══════════════════════════════════════════════════════════════

# ── Spring Profile ────────────────────────────────────────────
SPRING_PROFILES_ACTIVE=prod

# ── ActiveMQ Artemis (TMS side) ───────────────────────────────
ARTEMIS_HOST=10.4.0.23
ARTEMIS_PORT=61616
ARTEMIS_USER=pasbridge
ARTEMIS_PASS=changeme

# ── Apache Kafka ──────────────────────────────────────────────
KAFKA_HOST=10.4.0.23
KAFKA_PORT=9092
# For SASL_SSL (production):
KAFKA_USER=tms_bridge
KAFKA_PASS=changeme

# ── RabbitMQ (SCADA VM) ───────────────────────────────────────
RABBITMQ_HOST=10.4.0.25
RABBITMQ_PORT=5673
RABBITMQ_USER=thiru
RABBITMQ_PASS=changeme

# ── MQTT (via RabbitMQ plugin) ────────────────────────────────
MQTT_HOST=10.4.0.25
MQTT_PORT=1884
MQTT_USER=thiru
MQTT_PASS=changeme

# ── Encryption ────────────────────────────────────────────────
# AES-256-GCM key — Base64 encoded 32-byte key.
# Generate: openssl rand -base64 32
# MUST match the key used by the SCADA API to decrypt.
SCADA_AES_KEY=REPLACE_WITH_REAL_BASE64_KEY

# ── Bridge Pipeline ───────────────────────────────────────────
# Ordered delivery chain. Options: kafka, rabbitmq, mqtt
# Full chain:   kafka,rabbitmq,mqtt
# Skip Kafka:   rabbitmq,mqtt
# MQTT direct:  mqtt
BRIDGE_PIPELINE=kafka,rabbitmq,mqtt

# ── SCADA Creator ID ─────────────────────────────────────────
SCADA_CREATOR_ID=ScateX

# ── TLS (optional — uncomment when truststore is available) ──
# TLS_TRUSTSTORE_PATH=/opt/pinkline/certs/truststore.jks
# TLS_TRUSTSTORE_PASS=changeme

# ── Monitor API (optional — in-bridge message viewer) ─────────
BRIDGE_MONITOR_ENABLED=false
BRIDGE_MONITOR_FROM_EXCHANGE=amq.topic
BRIDGE_MONITOR_ROUTING_KEY=tms.scada.pas
BRIDGE_MONITOR_QUEUE=scada.monitor.queue
